from http.server import SimpleHTTPRequestHandler, HTTPServer
import urllib.parse

# This class handles incoming requests from the browser
class MySimpleWebServer(SimpleHTTPRequestHandler):
    
    # 1. Handle GET requests (when the user loads a page)
    def do_GET(self):
        # If they open the main site, redirect them to the login page
        if self.path == "/" or self.path == "":
            self.send_response(302)
            self.send_header("Location", "/login.html")
            self.end_headers()
        else:
            # Otherwise, use the built-in system to serve standard HTML/CSS files
            super().do_GET()

    # 2. Handle POST requests (when the user submits the login form)
    def do_POST(self):
        # We only process form submissions sent to '/login'
        if self.path == "/login":
            # Find out how many bytes of data were submitted in the form
            content_length = int(self.headers.get('Content-Length', 0))
            
            # Read that exact number of bytes and convert it from binary to text
            raw_post_data = self.rfile.read(content_length).decode('utf-8')
            
            # Parse the form data (e.g. "username=admin&password=123" -> Python dictionary)
            parsed_form = urllib.parse.parse_qs(raw_post_data)
            
            # Extract username and password values
            username = parsed_form.get('username', [''])[0]
            password = parsed_form.get('password', [''])[0]
            
            # Check the credentials and redirect to the correct page
            if username == "admin" and password == "admin123":
                # Redirect to the Admin page
                self.send_response(302)
                self.send_header("Location", "/admin.html")
                self.end_headers()
                
            elif username == "manager" and password == "manager123":
                # Redirect to the Manager page
                self.send_response(302)
                self.send_header("Location", "/manager.html")
                self.end_headers()
                
            elif username == "employee" and password == "employee123":
                # Redirect to the Employee page
                self.send_response(302)
                self.send_header("Location", "/employee.html")
                self.end_headers()
                
            else:
                # If incorrect, redirect back to login and append an error flag in the URL
                self.send_response(302)
                self.send_header("Location", "/login.html?error=1")
                self.end_headers()

# Function to start the server
def run_server(port=5000):
    server_address = ('127.0.0.1', port)
    httpd = HTTPServer(server_address, MySimpleWebServer)
    print(f"Server running! Open http://127.0.0.1:{port} in your browser.")
    httpd.serve_forever()

if __name__ == '__main__':
    run_server()